---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = site.description,
  image = '/assets/images/favicons/og-image.jpg',
  type = 'website',
} = Astro.props;

const fullTitle = title ? `${title} · ${site.title}` : site.title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en" class="bg-charcoal-900">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/assets/images/favicons/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/assets/images/favicons/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/assets/images/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1a1d21" />
    <meta name="msapplication-TileImage" content="/assets/images/favicons/mstile-270x270.png" />
    <meta name="msapplication-TileColor" content="#1a1d21" />

    <!-- Anti-FOUC: apply persisted/system theme before first paint -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        try {
          var c = document.cookie.match(/(?:^|;\s*)theme=(\w+)/);
          if (c) {
            d.setAttribute('data-theme', c[1]);
          } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
            d.setAttribute('data-theme', 'light');
          }
        } catch (e) {}
      })();
    </script>

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={title ?? site.title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? site.title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- GoSquared analytics -->
    <script is:inline>
      !(function (g, s, q, r, d) {
        r = g[r] = g[r] || function () {
          (r.q = r.q || []).push(arguments);
        };
        d = s.createElement(q);
        d.src = '//d1l6p2sc9645hc.cloudfront.net/gosquared.js';
        q = s.getElementsByTagName(q)[0];
        q.parentNode.insertBefore(d, q);
      })(window, document, 'script', '_gs');
      _gs('GSN-445036-A');
      _gs('set', 'anonymizeIP', true);
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-charcoal-900 text-aluminum-100 antialiased">
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:rounded-md focus:bg-aluminum-100 focus:px-4 focus:py-2 focus:text-charcoal-900"
      href="#main">Skip to content</a
    >
    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-aluminum-500/25 bg-charcoal-900">
      <div class="mx-auto flex w-full max-w-5xl flex-col gap-4 px-6 py-10 text-sm text-aluminum-400">
        <div class="flex flex-wrap items-center gap-3">
          <p>© {currentYear} {site.title}</p>
          <span aria-hidden="true">·</span>
          <p>
            Built with
            <a href="https://astro.build/" class="underline underline-offset-4 transition hover:text-ember-300 hover:underline">Astro</a>,
            <a href="https://react.dev/" class="underline underline-offset-4 transition hover:text-ember-300 hover:underline">React</a>,
            <a href="https://tailwindcss.com/" class="underline underline-offset-4 transition hover:text-ember-300 hover:underline">Tailwind CSS</a>,
            and
            <a href="https://gsap.com/" class="underline underline-offset-4 transition hover:text-ember-300 hover:underline">GSAP</a>.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
          <a class="underline underline-offset-4 transition hover:text-ember-300 hover:underline" href={`mailto:${site.social.email}`}>{site.social.email}</a>
          {site.social.linkedin && (
            <a class="underline underline-offset-4 transition hover:text-ember-300 hover:underline" href={site.social.linkedin}>LinkedIn</a>
          )}
          {site.social.github && (
            <a class="underline underline-offset-4 transition hover:text-ember-300 hover:underline" href={site.social.github}>GitHub</a>
          )}
          {site.social.medium && (
            <a class="underline underline-offset-4 transition hover:text-ember-300 hover:underline" href={site.social.medium}>Medium</a>
          )}
          <span aria-hidden="true">·</span>
          <div
            id="theme-picker"
            class="inline-flex rounded-full border border-aluminum-500/25 p-0.5 text-xs"
            role="radiogroup"
            aria-label="Colour scheme">
            <button type="button" data-theme-choice="light" class="theme-seg inline-flex items-center gap-1 rounded-full px-2.5 py-1 transition" role="radio" aria-checked="false">
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path></svg>
              Light
            </button>
            <button type="button" data-theme-choice="auto" class="theme-seg inline-flex items-center gap-1 rounded-full px-2.5 py-1 transition" role="radio" aria-checked="false">
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd"></path></svg>
              Auto
            </button>
            <button type="button" data-theme-choice="dark" class="theme-seg inline-flex items-center gap-1 rounded-full px-2.5 py-1 transition" role="radio" aria-checked="false">
              <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
              Dark
            </button>
          </div>
        </div>
      </div>
    </footer>

    <script>
      import '../scripts/theme-toggle.ts';
      import '../scripts/scroll-animations.ts';
      import '../scripts/page-nav.ts';
    </script>
  </body>
</html>
