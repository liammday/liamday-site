---
import BaseLayout from './BaseLayout.astro';
import { MetaList } from '../components/ui/MetaList';
import UpdateTimeline from '../components/UpdateTimeline.astro';

const { project } = Astro.props;
const data = project.data;

function fmtDay(d?: Date): string {
  return d ? d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '';
}

const items: { label: string; value: string }[] = [];
if (data.role) items.push({ label: 'Role', value: data.role });
if (data.date_published) items.push({ label: 'Published', value: fmtDay(data.date_published) });
else if (data.year != null) items.push({ label: 'Year', value: String(data.year) });
if (data.period) items.push({ label: 'Period', value: data.period });
if (data.client) items.push({ label: 'Client', value: data.client });
if (data.location) items.push({ label: 'Location', value: data.location });
if (data.outcome) items.push({ label: 'Outcome', value: data.outcome });

const navItems = data.nav ?? [];
const hasUpdates = (data.updates?.length ?? 0) > 0;
---

<BaseLayout title={data.title} description={data.description} type="article" image={data.image}>
  <article class="bg-charcoal-900 text-aluminum-100">
    <section class="border-b border-aluminum-500/25 bg-charcoal-900">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <a
          class="text-sm text-aluminum-300 underline-offset-4 transition hover:text-ember-300 hover:underline"
          href="/#projects">← Back to Projects</a
        >
        {
          data.type && (
            <p class="mt-8 text-xs font-semibold uppercase tracking-[0.35em] text-aluminum-400">{data.type}</p>
          )
        }
        <h1 class="mt-6 text-4xl font-semibold text-aluminum-100">{data.title}</h1>
        {
          data.hero_image && (
            <figure class="mt-10">
              <picture>
                {data.hero_image_webp && <source srcset={data.hero_image_webp} type="image/webp" />}
                <img
                  src={data.hero_image}
                  alt={data.hero_image_alt ?? data.title}
                  class="w-full rounded-2xl shadow-[0_20px_45px_-30px_rgba(0,0,0,0.9)]"
                  width={data.hero_image_width}
                  height={data.hero_image_height}
                  loading="eager"
                />
              </picture>
              {data.hero_image_caption && (
                <figcaption class="mt-3 text-xs text-aluminum-400">{data.hero_image_caption}</figcaption>
              )}
            </figure>
          )
        }
        {
          data.summary && (
            <p class:list={[data.hero_image ? 'mt-8' : 'mt-4', 'text-lg leading-relaxed text-aluminum-300']}>
              {data.summary}
            </p>
          )
        }
        {data.date_updated && <p class="mt-4 text-sm text-aluminum-400">Last updated: {fmtDay(data.date_updated)}</p>}
        <MetaList items={items} />
      </div>
    </section>

    {
      (navItems.length > 0 || hasUpdates) && (
        <nav
          class="sticky top-0 z-40 border-b border-aluminum-500/25 bg-charcoal-900/95 backdrop-blur"
          aria-label="Page sections"
          data-sticky-nav>
          <div class="page-nav-bleed flex gap-3 overflow-x-auto py-4 text-sm" data-nav-scroll>
            {navItems.map((item) => (
              <a
                class="whitespace-nowrap rounded-full border border-transparent px-4 py-2 font-medium text-aluminum-300 transition hover:border-aluminum-500/40 hover:text-aluminum-100 aria-[current=page]:border-ember-400/50 aria-[current=page]:bg-ember-500/10 aria-[current=page]:text-ember-200 aria-[current=page]:texture-noise"
                href={`#${item.id}`}
                data-nav-link>
                {item.label}
              </a>
            ))}
            {hasUpdates && (
              <a
                class="whitespace-nowrap rounded-full border border-transparent px-4 py-2 font-medium text-aluminum-300 transition hover:border-aluminum-500/40 hover:text-aluminum-100 aria-[current=page]:border-ember-400/50 aria-[current=page]:bg-ember-500/10 aria-[current=page]:text-ember-200 aria-[current=page]:texture-noise"
                href="#updates"
                data-nav-link>
                Updates
              </a>
            )}
          </div>
        </nav>
      )
    }

    <div class="mx-auto max-w-5xl px-6 py-16">
      <div class="detail-content prose prose-invert">
        <slot />
      </div>
    </div>

    {hasUpdates && <UpdateTimeline updates={data.updates} />}

    {
      data.links && (
        <div class="mx-auto max-w-5xl px-6 pb-20">
          <div class="surface-panel p-6">
            <h2 class="text-lg font-semibold text-aluminum-100">Further reading</h2>
            <ul class="mt-4 space-y-2 text-sm text-aluminum-300">
              {data.links.map((link) => (
                <li>
                  <a class="underline-offset-4 hover:text-ember-300 hover:underline" href={link.url}>
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )
    }
  </article>
</BaseLayout>
